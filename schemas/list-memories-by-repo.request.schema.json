{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-memory-fabric.dev/schemas/list-memories-by-repo.request.schema.json",
  "title": "ListMemoriesByRepoRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["tenant", "project", "repository", "scope"],
  "properties": {
    "tenant": { "type": "string", "minLength": 1, "maxLength": 128 },
    "project": { "type": "string", "minLength": 1, "maxLength": 128 },
    "repository": { "type": "string", "minLength": 1, "maxLength": 256 },
    "scope": {
      "type": "array",
      "items": { "type": "string", "enum": ["user", "repo", "project", "team", "org"] },
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true
    },
    "types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["decision", "bugfix", "incident", "note", "todo", "question", "fact", "convention", "summary"]
      },
      "maxItems": 9,
      "uniqueItems": true
    },
    "limit": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 }
  }
}
