{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-memory-fabric.dev/schemas/write-memory.request.schema.json",
  "title": "WriteMemoryRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant",
    "project",
    "repository",
    "scope",
    "visibility",
    "type",
    "summary",
    "author",
    "source"
  ],
  "properties": {
    "tenant": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "project": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "repository": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "scope": {
      "type": "string",
      "enum": ["user", "repo", "project", "team", "org"]
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "team", "org"]
    },
    "type": {
      "type": "string",
      "enum": ["decision", "bugfix", "incident", "note", "todo", "question", "fact", "convention", "summary"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "details": {
      "type": "string",
      "maxLength": 20000
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "maxItems": 50,
      "uniqueItems": true
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source_ref": {
      "type": "string",
      "maxLength": 512
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    }
  }
}
